        <div class="input-group mb-3">
            <input type="text" id="outcomes" class="form-control" placeholder="e.g., 1,0,1,1,0,0,1">
            <button class="btn btn-outline-secondary" onclick="addOutcome(1)">Add Win</button>
            <button class="btn btn-outline-secondary" onclick="addOutcome(0)">Add Loss</button>
        </div>
        <div id="edge_result" class="mt-3"></div>
        <button class="btn btn-success mt-2" onclick="runEdgeAnalysis()">Run Edge Analysis</button>
    </div>
</div>

<!-- MONTE CARLO SIMULATION -->
