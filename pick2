</div>

<script>
// ============== KELLY CRITERION ==============
function calculateKelly() {
    const p = parseFloat(document.getElementById('kelly_p').value);
    const b = parseFloat(document.getElementById('kelly_b').value);
    const q = 1 - p;
    const edge = p * b - q;
    const fullKelly = edge / b;
    
    let note = "Negative edge – NO STAKE ADVISED.";
    let recFraction = 0;
    if (fullKelly > 0) {
        note = "Positive edge detected!";
        recFraction = fullKelly / 4; // Quarter Kelly (conservative)
    }

    const html = `
        <div class="alert alert-${fullKelly > 0 ? 'success' : 'danger'}">
            <p><strong>Observed Win Rate:</strong> ${(p*100).toFixed(2)}%</p>
            <p><strong>Raw Edge (bp−q):</strong> ${edge.toFixed(4)}</p>
            <p><strong>Full Kelly Fraction:</strong> ${fullKelly.toFixed(4)}</p>
            <p><strong>Half Kelly:</strong> ${(fullKelly/2).toFixed(4)}</p>
            <p><strong>Quarter Kelly (Recommended):</strong> <strong>${recFraction.toFixed(4)}</strong></p>
            <p><strong>Note:</strong> ${note}</p>
        </div>
    `;
    document.getElementById('kelly_result').innerHTML = html;
}

// ============== EDGE DETECTION ==============
let outcomes = [];

function addOutcome(val) {
    outcomes.push(val);
    document.getElementById('outcomes').value = outcomes.join(',');
}

function runEdgeAnalysis() {
    const wins = outcomes.filter(x => x === 1).length;
    const total = outcomes.length;
    const winRate = total > 0 ? wins / total : 0;
    
    // Beta CI (approximation)
    const alpha = 0.05;
    const lower = winRate - 1.96 * Math.sqrt(winRate*(1-winRate)/total);
    const upper = winRate + 1.96 * Math.sqrt(winRate*(1-winRate)/total);
    
    // P-value (one-sided binomial test)
    const pValue = total > 0 ? 1 - Math.pow(1 - winRate, total) : 1;
    const significant = (lower > 0.5);

    const html = `
        <div class="alert alert-${significant ? 'success' : 'warning'}">
            <p><strong>Total Events:</strong> ${total}</p>
            <p><strong>Wins:</strong> ${wins} | <strong>Win Rate:</strong> ${(winRate*100).toFixed(2)}%</p>
            <p><strong>95% Confidence Interval:</strong> [${(lower*100).toFixed(1)}% – ${(upper*100).toFixed(1)}%]</p>
            <p><strong>P-value (one‑sided):</strong> ${pValue.toFixed(4)}</p>
            <p><strong>Statistical Edge:</strong> ${significant ? '✅ YES' : '❌ NO'}</p>
            <p><strong>Conclusion:</strong> 
                ${significant ? 
                  "Real statistical edge detected! Consider betting (¼ Kelly)." : 
                  "No significant edge. Avoid betting."}
            </p>
        </div>
    `;
    document.getElementById('edge_result').innerHTML = html;
}

// ============== MONTE CARLO SIMULATION ==============
function runMonteCarlo() {
    const winProb = parseFloat(document.getElementById('mc_p').value);
    const fraction = parseFloat(document.getElementById('mc_fraction').value);
    const initBank = parseFloat(document.getElementById('mc_bankroll').value);
    const nRounds = 500;
    const nSims = 1000;
    
    let finalBankrolls = [];
    
    for (let s = 0; s < nSims; s++) {
        let bankroll = initBank;
        let ruined = false;
        
        for (let r = 0; r < nRounds; r++) {
            const bet = bankroll * fraction;
            const outcome = Math.random() < winProb ? 1 : 0;
            
            if (outcome === 1) {
                bankroll += bet; // odds = 1.0 (double stake)
            } else {
                bankroll -= bet;
            }
            
            // Ruin condition
            if (bankroll <= 0) {
                ruined = true;
                break;
            }
        }
        finalBankrolls.push(bankroll);
    }
    
    const median = finalBankrolls.sort((a,b)=>a-b)[Math.floor(finalBankrolls.length/2)];
    const p10 = finalBankrolls[Math.floor(finalBankrolls.length*0.1)];
    const p90 = finalBankrolls[Math.floor(finalBankrolls.length*0.9)];
    const ruinPct = finalBankrolls.filter(b => b <= 0).length / nSims;
    
    // Update Chart
    const ctx = document.getElementById('bankrollChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: Array.from({length: nRounds+1}, (_,i) => i),
            datasets: [{
                label: 'Median Bankroll',
                data: [initBank, ...Array(nRounds).fill(median)],
                borderColor: 'rgb(75, 192, 192)',
                tension: 0.1
            }]
        },
        options: { 
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });
    
    const html = `
        <div class="alert alert-info">
            <p><strong>Median Final Bankroll:</strong> £${median.toFixed(2)}</p>
            <p><strong>10th / 90th Percentile:</strong> £${p10.toFixed(2)} – £${p90.toFixed(2)}</p>
            <p><strong>Ruin Probability:</strong> ${(ruinPct*100).toFixed(2)}%</p>
            <p><strong>Growth Factor (Median):</strong> ${(median/initBank).toFixed(2)}×</p>
        </div>
    `;
    document.getElementById('mc_result').innerHTML = html;
}
</script>

