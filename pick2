<!-- KELLY CRITERION -->
<div class="card">
    <div class="card-header bg-success text-white">
        <h2 class="h5 mb-0">1️⃣ Kelly Criterion</h2>
    </div>
    <div class="card-body">
        <p>Computes optimal stake size using the <strong>Kelly Criterion</strong>:</p>
        <div class="code-block">
            f* = (bp - q) / b <br>
            Where: 
            <ul>
                <li>b = net odds (e.g., 1.0 = double your stake)</li>
                <li>p = win probability</li>
                <li>q = 1 - p</li>
            </ul>
        </div>
        <h5>When to use:</h5>
        <ul>
            <li>Positive edge: Bet ¼ Kelly (conservative)</li>
            <li>Negative edge: <strong>Do NOT bet</strong></li>
        </ul>
        
        <h5 class="mt-4">Try it yourself!</h5>
        <div class="row">
            <div class="col-md-4">
                <label>Win Probability (p)</label>
                <input type="number" id="kelly_p" class="form-control" min="0.01" max="0.99" step="0.01" value="0.53">
            </div>
            <div class="col-md-4">
                <label>Odds (b)</label>
                <input type="number" id="kelly_b" class="form-control" min="0.1" step="0.1" value="1.0">
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-primary" onclick="calculateKelly()">Calculate</button>
            </div>
        </div>
        <div id="kelly_result" class="mt-3"></div>
    </div>
</div>

<!-- EDGE DETECTION -->
<div class="card">
